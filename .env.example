# Profile Store Configuration
# Options: "memory" (default, for development) or "postgres"
PROFILE_STORE=memory

# PostgreSQL Configuration
# Required only if PROFILE_STORE=postgres
DATABASE_URL=postgresql://user:password@localhost:5432/news_scrapper
# OR use individual PG* environment variables:
PGHOST=localhost
PGPORT=5432
PGDATABASE=news_scrapper
PGUSER=postgres
PGPASSWORD=password

# API Server Configuration
PORT=4300
API_HOST=127.0.0.1

# Frontend Development Configuration
API_PROXY_TARGET=http://127.0.0.1:4300
VITE_API_BASE=/api

# Logging Configuration
# Options: "debug", "info", "warn", "error"
LOG_LEVEL=info

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=false

# Service Name for OTEL
OTEL_SERVICE_NAME=news-scraper

# GitHub Webhook Configuration (for news scraping trigger)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# News Scraping Workflow Configuration
SCRAP_WORKFLOW_URL=https://api.github.com/repos/your-org/your-repo/actions/workflows/scrape.yml/dispatches
SCRAP_WORKFLOW_TOKEN=ghp_your-github-token

# Environment-aware scrape webhook configuration (preferred)
# Store Production values in a *.prod.env file and Test values in a *.test.env file.
# Keep the variable names below unchanged in each file.
SCRAP_WEBHOOK_URL=
N8N_WORKFLOW_URL=
BASIC_AUTH_USER=
BASIC_AUTH_PWD=

# Notification Services (optional)
# Email notification configuration
NOTIFICATION_EMAIL_HOST=smtp.gmail.com
NOTIFICATION_EMAIL_PORT=587
NOTIFICATION_EMAIL_USER=your-email@gmail.com
NOTIFICATION_EMAIL_PASSWORD=your-app-password

# Slack notification configuration
SLACK_BOT_TOKEN=xoxb-your-slack-token

# Feature Flags
ENABLE_NEWS_SCRAPING=true
ENABLE_NOTIFICATIONS=false
ENABLE_PROFILE_SHARING=false

# Development Mode (set to "true" in development)
DEBUG=false
NODE_ENV=development
