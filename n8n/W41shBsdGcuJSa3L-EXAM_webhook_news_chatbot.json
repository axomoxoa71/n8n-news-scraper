    {
      "parameters": {
        "promptType": "define",
        "text": "=# Role\nYou act as user asking a questions and need to evaluate the answer according to the question given STRICTLY and CRITICAL.\n\nYour goal is to check:\n\"Did the user literally get what they asked for?\"\n\nUser question: \n{{ $json.userMessage }}\nAnswer:\n{{ $json.assistantMessage }}\n\nRules:\n- For not news related question you MUST set rate -1\n- For all question related to news consider below rating:\n- If user did not get any answer the initial question answer rate 0\n- If user got the question partially answered rate 5\n- Any question back to user, or do not, did not, can not should cut of -1\n- Any concrete answer to question you can rate up +1\n- Check and consider if user asks for sepecific count if answer considered that. e.g. give me top 10 news must provide 10 news back\n\nReturn:\n{\n  \"quality\": <-1 to 10>\n}\n\n-1 out of news context (any non news related question or task)\n0 is worst \n10 is best ",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "="
        }
      },
