{
  "name": "ai-news-scrapper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run stop:api && concurrently -k -n api,web \"npm run dev:api\" \"npx wait-on tcp:127.0.0.1:4300 && npm run dev:client\"",
    "dev:pretty": "npm run stop:api && concurrently -k -n api,web \"npm run dev:api:pretty\" \"npx wait-on tcp:127.0.0.1:4300 && npm run dev:client\"",
    "predev:api": "npm run stop:api",
    "dev:api": "node server/src/index.mjs",
    "dev:api:pretty": "node server/src/index.mjs | pino-pretty --colorize --translateTime",
    "dev:client": "vite",
    "dev:test": "npm run stop:api && concurrently -k -n api,web \"cross-env PORT=4301 npm run dev:api\" \"npx wait-on tcp:127.0.0.1:4301 && cross-env API_PROXY_TARGET=http://127.0.0.1:4301 vite --host 127.0.0.1 --port 4173\"",
    "build": "vite build",
    "prestart:api": "npm run stop:api",
    "start:api": "node server/src/index.mjs",
    "stop:api": "kill-port 4300",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:api": "node --test server/news-scraper-api.test.mjs",
    "test:seed": "node --test server/seed-data.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "openapi:preview": "npx swagger-ui-watcher documentation/api/news-scraper-openapi.yaml --port 8090 --no-open",
    "openapi:build": "npx @redocly/cli build-docs documentation/api/news-scraper-openapi.yaml -o documentation/api/html/news-scraper-openapi.html",
    "seed:profiles": "node server/scripts/seed-profiles.mjs",
    "seed:sql": "psql \"$DATABASE_URL\" -f server/sql/seed.sql",
    "seed:news:sql": "psql \"$DATABASE_URL\" -f server/sql/seed-news.sql",
    "db-clean": "psql \"$DATABASE_URL\" -f server/sql/cleanup-data.sql"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "kill-port": "^2.0.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}